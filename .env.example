# ── Azure OpenAI Service ───────────────────────────────────────────────────────
# Solo la URL base — SIN ruta ni query params
# Ejemplo cognitiveservices: https://mi-recurso.cognitiveservices.azure.com
# Ejemplo openai clásico:    https://mi-recurso.openai.azure.com
AZURE_AI_ENDPOINT=
# API Key del recurso
AZURE_AI_KEY=

# Nombre exacto del deployment configurado en Azure AI Foundry
AZURE_AI_MODEL=gpt-5.3-chat-unbreaken

# Versión de API (no cambiar salvo que Azure lo requiera)
AZURE_AI_API_VERSION=2025-04-01-preview

# ── Azure DevOps (FUENTE PRIMARIA) ────────────────────────────────────────────
# URL de tu organización ADO
ADO_ORG_URL=https://dev.azure.com

# Personal Access Token — permisos mínimos: Code (Read) + Project and Team (Read)
ADO_PAT=

# Nombre exacto del proyecto en ADO
ADO_PROJECT=

# Repos a pre-calentar al arrancar (separados por coma). Opcional.
# En runtime cualquier repo se carga dinámicamente al primer request.
ADO_REPOS=SkCo.PortfolioManagement.Angular,SkCo.ProfileModule.Angular

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201
